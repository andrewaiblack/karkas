export PRESET_BASE="mainnet"
export CHAIN_ID="144114"

# IMPORTANT: Replace this mnemonic with your own generated one.
# Generate with: docker run --rm ethpandaops/ethereum-genesis-generator:master eth2-val-tools mnemonic
# NEVER use this placeholder mnemonic on a real network.
export EL_AND_CL_MNEMONIC="REPLACE_WITH_YOUR_OWN_24_WORD_MNEMONIC_GENERATED_LOCALLY"

# Validator set size at genesis
export NUMBER_OF_VALIDATORS="8"
export VALIDATOR_BALANCE="32000000000"

# Genesis timing
export GENESIS_TIMESTAMP="${GENESIS_TIMESTAMP:-0}"
export GENESIS_DELAY="60"

# Slot timing
export SLOT_DURATION_IN_SECONDS="12"
export SLOT_DURATION_MS="12000"

# Withdrawal credentials (0x00 = BLS)
export WITHDRAWAL_TYPE="0x00"

# EL premine for faucet wallet
# Set EL_PREMINE_ADDRS to your faucet wallet address (matches FAUCET_PRIVATE_KEY in .env.local)
export EL_PREMINE_COUNT="0"
export EL_PREMINE_ADDRS='{"0xYOUR_FAUCET_WALLET_ADDRESS":{"balance":"1000000000ETH"}}'
