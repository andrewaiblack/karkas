# Copy to .env and fill in real values. Never commit .env to git.

# Required — Ethereum private key of the faucet wallet (no 0x prefix needed)
FAUCET_PRIVATE_KEY=your_private_key_here

# Internal RPC URL (geth / execution client inside Docker network)
RPC_URL=http://execution:8545

# Public RPC served to users via /api/info
FAUCET_PUBLIC_RPC=https://rpc.marakyja.xyz

# Block explorer URL
FAUCET_EXPLORER_URL=https://explorer.marakyja.xyz

# Chain ID
FAUCET_CHAIN_ID=444114

# Amount to send per claim (in Wei). 1 KRKS = 1000000000000000000
FAUCET_AMOUNT_WEI=1000000000000000000

# Server port
FAUCET_PORT=5000

# Comma-separated list of origins allowed by CORS.
# Must match the exact Origin header browsers send (include https://)
ALLOWED_ORIGINS=https://faucet.marakyja.xyz
