################################################################################
#  KARKAS TESTNET — CENTRAL CONFIGURATION
#  Edit this file to customise your testnet. All scripts, genesis generation,
#  docker-compose, faucet and Blockscout pull values from here.
################################################################################

# ─── NETWORK IDENTITY ─────────────────────────────────────────────────────────
NETWORK_NAME=karkas
CHAIN_ID=144411
NETWORK_ID=144411

# Token / currency displayed in wallets and explorer
CURRENCY_NAME=KARKAS
CURRENCY_SYMBOL=KRKS
CURRENCY_DECIMALS=18

# ─── DOMAIN / URLS ────────────────────────────────────────────────────────────
# Set to your actual domain (used by Blockscout and faucet UI).
# For local-only use, keep 'localhost'.
BASE_DOMAIN=localhost
RPC_URL=http://localhost:8545
EXPLORER_URL=http://localhost:4000

# ─── PORTS ────────────────────────────────────────────────────────────────────
EXECUTION_HTTP_PORT=8545
EXECUTION_WS_PORT=8546
EXECUTION_P2P_PORT=30303

CONSENSUS_HTTP_PORT=5052
CONSENSUS_P2P_TCP=9000
CONSENSUS_P2P_UDP=9000
CONSENSUS_METRICS_PORT=5054

FAUCET_PORT=5000
LANDING_PORT=3000

# ─── CONSENSUS LAYER SETTINGS ─────────────────────────────────────────────────
PRESET_BASE=mainnet
GENESIS_DELAY=60
SLOT_DURATION_IN_SECONDS=12
SLOT_DURATION_MS=12000
SECONDS_PER_ETH1_BLOCK=12
NUMBER_OF_VALIDATORS=64
VALIDATOR_BALANCE=32000000000

# Fork versions (hex, must be unique per network)
GENESIS_FORK_VERSION=0x10000000
ALTAIR_FORK_VERSION=0x20000000
BELLATRIX_FORK_VERSION=0x30000000
CAPELLA_FORK_VERSION=0x40000000
DENEB_FORK_VERSION=0x50000000
ELECTRA_FORK_VERSION=0x60000000
FULU_FORK_VERSION=0x70000000
GLOAS_FORK_VERSION=0x80000000
HEZE_FORK_VERSION=0x90000000
EIP7928_FORK_VERSION=0xa0000000

# Fork activation epochs (18446744073709551615 = disabled)
ALTAIR_FORK_EPOCH=0
BELLATRIX_FORK_EPOCH=0
CAPELLA_FORK_EPOCH=0
DENEB_FORK_EPOCH=0
ELECTRA_FORK_EPOCH=18446744073709551615
FULU_FORK_EPOCH=18446744073709551615
GLOAS_FORK_EPOCH=18446744073709551615
HEZE_FORK_EPOCH=18446744073709551615
EIP7928_FORK_EPOCH=18446744073709551615

TERMINAL_TOTAL_DIFFICULTY=0
MIN_VALIDATOR_WITHDRAWABILITY_DELAY=256
SHARD_COMMITTEE_PERIOD=256
ETH1_FOLLOW_DISTANCE=16
EJECTION_BALANCE=16000000000
MIN_PER_EPOCH_CHURN_LIMIT=4
CHURN_LIMIT_QUOTIENT=65536
MAX_PER_EPOCH_ACTIVATION_CHURN_LIMIT=8
MIN_PER_EPOCH_CHURN_LIMIT_ELECTRA=128000000000
MAX_PER_EPOCH_ACTIVATION_EXIT_CHURN_LIMIT=256000000000
MAX_PAYLOAD_SIZE=10485760
MAX_REQUEST_BLOCKS_DENEB=128
MIN_EPOCHS_FOR_BLOB_SIDECARS_REQUESTS=4096
MAX_BLOBS_PER_BLOCK_ELECTRA=9
SAMPLES_PER_SLOT=8
CUSTODY_REQUIREMENT=4
MIN_EPOCHS_FOR_DATA_COLUMN_SIDECARS_REQUESTS=4096
MIN_BUILDER_WITHDRAWABILITY_DELAY=4096
ATTESTATION_DUE_BPS_GLOAS=2500
AGGREGATE_DUE_BPS_GLOAS=5000
SYNC_MESSAGE_DUE_BPS_GLOAS=2500
CONTRIBUTION_DUE_BPS_GLOAS=5000
PAYLOAD_ATTESTATION_DUE_BPS=7500
VIEW_FREEZE_CUTOFF_BPS=7500
INCLUSION_LIST_SUBMISSION_DUE_BPS=6667
PROPOSER_INCLUSION_LIST_CUTOFF_BPS=9167

# Validator withdrawal type: 0x00=BLS, 0x01=execution address
WITHDRAWAL_TYPE=0x01

# ─── FAUCET SETTINGS ──────────────────────────────────────────────────────────
# Amount sent per faucet request (in wei).  Default = 1 ETH
FAUCET_AMOUNT_WEI=1000000000000000000
# Cooldown period in hours
FAUCET_RATE_LIMIT_HOURS=24

# ─── BLOCKSCOUT ───────────────────────────────────────────────────────────────
BLOCKSCOUT_PORT=4000
# Leave blank to auto-generate on first run (see 00-init-secrets.sh)
BLOCKSCOUT_DB_PASSWORD=
BLOCKSCOUT_SECRET_KEY_BASE=

# ─── DEPOSIT CONTRACT ─────────────────────────────────────────────────────────
# Auto-populated by genesis generator; you can override here if needed.
DEPOSIT_CONTRACT_ADDRESS=

# ─── FAUCET PREMINE ───────────────────────────────────────────────────────────
FAUCET_PREMINE_AMOUNT=1000000ETH
