# Copy to blockscout/.env.local and fill in — NEVER commit this file.

# PostgreSQL password (choose a strong random password)
BLOCKSCOUT_DB_PASSWORD=change_me_strong_password

# Full DATABASE_URL for blockscout backend
BLOCKSCOUT_DATABASE_URL=postgresql://blockscout:change_me_strong_password@db:5432/blockscout

# Generate with: openssl rand -hex 64
BLOCKSCOUT_SECRET_KEY_BASE=REPLACE_WITH_OUTPUT_OF__openssl_rand_-hex_64
